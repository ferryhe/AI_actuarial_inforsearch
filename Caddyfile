(json_access_log) {
	log {
		output file /data/access.log {
			roll_size 50MiB
			roll_keep 5
		}
		format json
	}
}

(baseline_security_headers) {
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
	}
}

(app_security_headers) {
	import baseline_security_headers
	header {
		Content-Security-Policy "{$CONTENT_SECURITY_POLICY:default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data: blob: https:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ws: wss:}"
	}
}

http://localhost:80 {
	bind 127.0.0.1 [::1]
	respond "ok" 200
}

{$CADDY_APP_SITE_HOSTS:http://localhost:8080} {
	import json_access_log
	import app_security_headers

	handle /api/* {
		reverse_proxy api:5000
	}

	handle {
		reverse_proxy frontend:5173
	}
}

{$CADDY_CROSS_SITE_HOST:http://localhost:8081} {
	import json_access_log
	import baseline_security_headers

	reverse_proxy {$CADDY_CROSS_UPSTREAM:host.docker.internal:8501}
}
