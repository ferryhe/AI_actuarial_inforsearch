modules = ["python-3.11"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Flask API"

[[workflows.workflow]]
name = "Flask API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 -m ai_actuarial web --host 0.0.0.0 --port 8000"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "webview"

[deployment]
deploymentTarget = "autoscale"
run = ["python3", "-m", "ai_actuarial", "web", "--host", "0.0.0.0", "--port", "8000"]
build = ["python3", "-m", "compileall", "ai_actuarial"]

[agent]
mockupState = "PYTHON_APP"
integrations = ["github:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["cargo", "freetype", "lcms2", "libGL", "libGLU", "libiconv", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "libyaml", "mesa", "openjpeg", "openssl", "pkg-config", "rustc", "tcl", "tk", "zlib"]

[[ports]]
localPort = 8000
externalPort = 80

[userenv]

[userenv.shared]
ENABLE_GLOBAL_LOGS_API = "True"
