# AI Actuarial Info Search - Environment Variables Example
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!

# ===================================
# SENSITIVE CREDENTIALS ONLY
# ===================================
# Non-sensitive configuration has been moved to config/sites.yaml
# Edit configuration via Web UI Settings page or config/sites.yaml directly

# ===================================
# API Keys
# ===================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Get from: https://brave.com/search/api/
BRAVE_API_KEY=

# Get from: https://serpapi.com/
SERPAPI_API_KEY=

# Get from: https://console.mistral.ai/
MISTRAL_API_KEY=

# Get from: https://siliconflow.cn/
SILICONFLOW_API_KEY=

# Optional AI provider keys used by runtime calls and model-list discovery
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
ZHIPUAI_API_KEY=
MOONSHOT_API_KEY=
KIMI_API_KEY=
DASHSCOPE_API_KEY=
COHERE_API_KEY=
MINIMAX_API_KEY=

# Get from: https://serper.dev/
SERPER_API_KEY=

# Get from: https://tavily.com/
TAVILY_API_KEY=

# Get from: https://mathpix.com/
MATHPIX_APP_ID=
MATHPIX_APP_KEY=

# ===================================
# API Base URLs (Optional Overrides)
# ===================================
# Override for OpenAI-compatible services (default: https://api.openai.com/v1)
#OPENAI_BASE_URL=https://api.openai.com/v1

# Override for Mistral API (default: https://api.mistral.ai)
#MISTRAL_BASE_URL=https://api.mistral.ai

# Override for SiliconFlow API (default: https://api.siliconflow.cn)
#SILICONFLOW_BASE_URL=https://api.siliconflow.cn

# Optional model-list discovery base URL overrides
#OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
#DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
#ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
#KIMI_BASE_URL=https://api.moonshot.cn/v1
#DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#MINIMAX_BASE_URL=https://api.minimax.chat/v1
#VLLM_BASE_URL=http://localhost:8001/v1
#LOCALAI_BASE_URL=http://localhost:8080/v1

# ===================================
# Database Configuration
# ===================================
# SQLite database file path (default: ./data/index.db)
#DB_PATH=./data/index.db

# ===================================
# Secret Keys
# ===================================
# FastAPI session secret for email/session login
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
#FASTAPI_SESSION_SECRET=
# Mark session cookies Secure for HTTPS deployments. If omitted, this defaults
# to true when FASTAPI_ENV=production and REQUIRE_AUTH=true.
#FASTAPI_SESSION_COOKIE_SECURE=true

# Token encryption key for provider/API credential management
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# This key is required to decrypt provider credentials stored in the database.
# The service now fails fast if TOKEN_ENCRYPTION_KEY is missing.
# Do NOT rely on auto-generated or file-based fallback keys.
# Keep this key stable across restarts/deployments and back it up securely.
# If it changes or is lost, all previously stored provider credentials become unreadable.
TOKEN_ENCRYPTION_KEY=

# ===================================
# Admin Auth Tokens (protect sensitive operations)
# ===================================
# Token for write access to /api/ops-write/* endpoints (e.g. config updates, task control)
#CONFIG_WRITE_AUTH_TOKEN=

# Token for read access to /api/ops-read/* endpoints (e.g. logs, stats)
#LOGS_READ_AUTH_TOKEN=

# Token required for file deletion operations
#FILE_DELETION_AUTH_TOKEN=

# ===================================
# Logging
# ===================================
# LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ===================================
# CONFIGURATION MOVED TO sites.yaml
# ===================================
# The following configuration options are now in config/sites.yaml:
# - AI model selections (catalog, embeddings, chatbot, ocr)
# - RAG settings (chunking, similarity, index type)
# - Feature flags (auth, deletion, rate limiting)
# - Server settings (host, port, max upload size)
# - Timeouts, retries, temperature, tokens, etc.
#
# Edit via Web UI Settings page or edit config/sites.yaml directly.
# Changes to sites.yaml take effect immediately (no restart needed).
#
# Backward compatibility: If sections are missing from sites.yaml,
# the system will fall back to reading from environment variables.

# ===================================
# OPTIONAL: Environment Variable Overrides
# ===================================
# For backward compatibility, you can still use environment variables.
# These will be used if the corresponding section is missing from sites.yaml.
#
# Chatbot Configuration:
#CHATBOT_MODEL=gpt-4o
#CHATBOT_TEMPERATURE=0.7
#CHATBOT_MAX_TOKENS=1000
#CHATBOT_TOP_K=5
#
# RAG Configuration:
#RAG_EMBEDDING_PROVIDER=openai
#RAG_EMBEDDING_MODEL=text-embedding-3-large
#RAG_INDEX_TYPE=Flat
#RAG_SIMILARITY_THRESHOLD=0.4
#RAG_CHUNK_STRATEGY=semantic_structure
#RAG_MAX_CHUNK_TOKENS=800
#RAG_MIN_CHUNK_TOKENS=100
#
# OCR Engine Configuration:
#DEFAULT_ENGINE=opendataloader
#MISTRAL_DEFAULT_MODEL=mistral-ocr-latest
#MISTRAL_TIMEOUT_SECONDS=60
#SILICONFLOW_DEFAULT_MODEL=deepseek-ai/DeepSeek-OCR
#SILICONFLOW_TIMEOUT_SECONDS=60
#MATHPIX_TIMEOUT_SECONDS=120
#MATHPIX_RETRY_ATTEMPTS=3
#MATHPIX_POLL_INTERVAL_SECONDS=5
#MATHPIX_OUTPUT_FORMAT=md
#MATHPIX_BASE_URL=https://api.mathpix.com/v3
#MARKITDOWN_ENABLE_PLUGINS=true
#MARKITDOWN_ENABLE_BUILTINS=true
#OPENDATALOADER_HYBRID=
#OPENDATALOADER_USE_STRUCT_TREE=false
#
# Server Configuration:
#FASTAPI_ENV=production
#FASTAPI_HOST=0.0.0.0
#FASTAPI_PORT=5000
#MAX_CONTENT_LENGTH=52428800
