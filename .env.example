# AI Actuarial Info Search - Environment Variables Example
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!

# ===================================
# SENSITIVE CREDENTIALS ONLY
# ===================================
# Non-sensitive configuration has been moved to config/sites.yaml
# Edit configuration via Web UI Settings page or config/sites.yaml directly

# ===================================
# API Keys
# ===================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Get from: https://brave.com/search/api/
BRAVE_API_KEY=

# Get from: https://serpapi.com/
SERPAPI_API_KEY=

# Get from: https://console.mistral.ai/
MISTRAL_API_KEY=

# Get from: https://siliconflow.cn/
SILICONFLOW_API_KEY=

# ===================================
# API Base URLs (Optional Overrides)
# ===================================
# Override for OpenAI-compatible services (default: https://api.openai.com/v1)
#OPENAI_BASE_URL=https://api.openai.com/v1

# Override for Mistral API (default: https://api.mistral.ai)
#MISTRAL_BASE_URL=https://api.mistral.ai

# Override for SiliconFlow API (default: https://api.siliconflow.cn)
#SILICONFLOW_BASE_URL=https://api.siliconflow.cn

# ===================================
# Database Configuration
# ===================================
# SQLite database file path (default: ./data/ai_actuarial.db)
#DATABASE_PATH=./data/ai_actuarial.db

# ===================================
# Secret Keys
# ===================================
# Flask secret key for session management (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here

# Token encryption key for API token management (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# This key is used to encrypt API tokens stored in the database
# IMPORTANT: Keep this key secure and backed up. If lost, all stored API tokens will be unrecoverable.
TOKEN_ENCRYPTION_KEY=

# ===================================
# CONFIGURATION MOVED TO sites.yaml
# ===================================
# The following configuration options are now in config/sites.yaml:
# - AI model selections (catalog, embeddings, chatbot, ocr)
# - RAG settings (chunking, similarity, index type)
# - Feature flags (auth, deletion, rate limiting)
# - Server settings (host, port, max upload size)
# - Timeouts, retries, temperature, tokens, etc.
#
# Edit via Web UI Settings page or edit config/sites.yaml directly.
# Changes to sites.yaml take effect immediately (no restart needed).
#
# Backward compatibility: If sections are missing from sites.yaml,
# the system will fall back to reading from environment variables.

# ===================================
# OPTIONAL: Environment Variable Overrides
# ===================================
# For backward compatibility, you can still use environment variables.
# These will be used if the corresponding section is missing from sites.yaml.
#
# Chatbot Configuration:
#CHATBOT_MODEL=gpt-4o
#CHATBOT_TEMPERATURE=0.7
#CHATBOT_MAX_TOKENS=1000
#CHATBOT_TOP_K=5
#
# RAG Configuration:
#RAG_EMBEDDING_PROVIDER=openai
#RAG_EMBEDDING_MODEL=text-embedding-3-large
#RAG_INDEX_TYPE=Flat
#RAG_SIMILARITY_THRESHOLD=0.4
#RAG_CHUNK_STRATEGY=semantic_structure
#RAG_MAX_CHUNK_TOKENS=800
#RAG_MIN_CHUNK_TOKENS=100
#
# OCR Engine Configuration:
#DEFAULT_ENGINE=local
#MISTRAL_DEFAULT_MODEL=mistral-ocr-latest
#MISTRAL_TIMEOUT_SECONDS=60
#SILICONFLOW_DEFAULT_MODEL=deepseek-ai/DeepSeek-OCR
#SILICONFLOW_TIMEOUT_SECONDS=60
#
# Server Configuration:
#FLASK_ENV=production
#FLASK_DEBUG=false
#FLASK_HOST=0.0.0.0
#FLASK_PORT=5000
#MAX_CONTENT_LENGTH=52428800
