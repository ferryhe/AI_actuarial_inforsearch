# AI Actuarial Info Search - .env Example
# Copy to .env for local/deployment secrets only.
# Do not commit real .env files.

# Main runtime configuration lives in config/sites.yaml and can be edited from
# the Settings page. Provider API keys should be saved as encrypted DB
# credentials from Settings, then referenced by credential id in sites.yaml.

# ===================================
# Required Secrets
# ===================================
# Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
FASTAPI_SESSION_SECRET=

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Keep this stable. Rotating or losing it makes encrypted DB credentials unreadable.
TOKEN_ENCRYPTION_KEY=

# ===================================
# Optional Admin Recovery
# ===================================
# Set only when you need API-token login for local/admin recovery.
# BOOTSTRAP_ADMIN_TOKEN=
# BOOTSTRAP_ADMIN_SUBJECT=bootstrap-admin

# Extra compatibility checks for older direct write/log/delete endpoints.
# Leave unset unless you intentionally want matching X-Auth-Token enforcement.
# CONFIG_WRITE_AUTH_TOKEN=
# LOGS_READ_AUTH_TOKEN=
# FILE_DELETION_AUTH_TOKEN=

# ===================================
# Optional Deployment Overrides
# ===================================
# FASTAPI_ENV=production
# FASTAPI_SESSION_COOKIE_SECURE=true
# Comma-separated origins, not JSON.
# FASTAPI_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# TRUST_PROXY=true

# config/sites.yaml -> paths.db is canonical. Use DB_PATH only for legacy
# configs or explicit deployment override when paths.db is absent.
# DB_PATH=./data/index.db

# Provider API keys are intentionally not listed here. If you must bootstrap
# from environment variables, add the needed provider key temporarily in your
# real .env, import it into encrypted DB credentials, verify runtime uses DB,
# then remove the provider key from .env.
