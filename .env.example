# AI Actuarial Info Search - Environment Variables Example
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!

# ===================================
# Database Configuration
# ===================================
DB_TYPE=sqlite
DB_PATH=data/index.db

# For PostgreSQL (production):
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=ai_actuarial
# DB_USER=your-db-username
# DB_PASSWORD=your-strong-db-password

# ===================================
# Search API Keys
# ===================================
# Get from: https://brave.com/search/api/
BRAVE_API_KEY=

# Get from: https://serpapi.com/
SERPAPI_API_KEY=

# ===================================
# Cataloging (LLM) API Keys
# ===================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# For OpenAI-compatible gateways (optional). Default: https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1
# Default model for cataloging (summary/keywords/category)
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=60

# ===================================
# RAG Configuration
# ===================================
# Embedding provider: openai or local
RAG_EMBEDDING_PROVIDER=openai
# Embedding model (OpenAI: text-embedding-3-large/small, ada-002)
RAG_EMBEDDING_MODEL=text-embedding-3-large
# Index type: Flat (exact), IVF (fast approx), HNSW (graph)
RAG_INDEX_TYPE=Flat
# Similarity threshold (0.0 - 1.0)
RAG_SIMILARITY_THRESHOLD=0.4
# Chunking settings
RAG_CHUNK_STRATEGY=semantic_structure
RAG_MAX_CHUNK_TOKENS=800
RAG_MIN_CHUNK_TOKENS=100

# ===================================
# Markdown Conversion Engine API Keys
# ===================================
# Get from: https://console.mistral.ai/
MISTRAL_API_KEY=

# Get from: https://siliconflow.cn/
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# ===================================
# Security Tokens
# ===================================
# Generate strong random tokens using:
# python -c "import secrets; print(secrets.token_urlsafe(32))"

# Required for configuration write operations
CONFIG_WRITE_AUTH_TOKEN=

# Required for file deletion operations (if ENABLE_FILE_DELETION=true)
FILE_DELETION_AUTH_TOKEN=

# Flask secret key for session management
FLASK_SECRET_KEY=

# Bootstrap admin token (public deployments)
# If set, the server will ensure an admin token exists matching this value.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
BOOTSTRAP_ADMIN_TOKEN=
BOOTSTRAP_ADMIN_SUBJECT=bootstrap-admin

# ===================================
# Feature Flags
# ===================================
# Enable file deletion feature (default: false)
ENABLE_FILE_DELETION=false

# Require authentication for all API endpoints (recommended: true)
REQUIRE_AUTH=false

# CSRF protection (recommended if using cookie sessions)
ENABLE_CSRF=false

# Security headers (recommended for public)
ENABLE_SECURITY_HEADERS=true
# Optional CSP (tune to your deployment). Leave empty to disable CSP header.
CONTENT_SECURITY_POLICY=

# Expose exception details to API clients on 500s (debug only; never enable on public)
EXPOSE_ERROR_DETAILS=false

# Enable global log viewer API endpoint (/api/logs/global). Recommended: false on public.
ENABLE_GLOBAL_LOGS_API=false
LOGS_READ_AUTH_TOKEN=

# Rate limiting (recommended for public)
ENABLE_RATE_LIMITING=false
# Default limiter rules applied to all endpoints when enabled (comma/semicolon separated).
RATE_LIMIT_DEFAULTS=200 per hour, 50 per minute
# Limiter backend. For multi-process deployments, use Redis (e.g. redis://host:6379).
RATE_LIMIT_STORAGE_URI=memory://

# ===================================
# Conversion Engine Settings
# ===================================
# Engine default selection (doc_to_md)
DEFAULT_ENGINE=local

# Docling tuning
DOCLING_MAX_PAGES=
DOCLING_RAISE_ON_ERROR=true

# Marker tuning
MARKER_USE_LLM=false
MARKER_PROCESSORS=
MARKER_PAGE_RANGE=
MARKER_EXTRACT_IMAGES=false
MARKER_LLM_SERVICE=

# Mistral API settings
MISTRAL_DEFAULT_MODEL=mistral-ocr-latest
MISTRAL_TIMEOUT_SECONDS=60
MISTRAL_RETRY_ATTEMPTS=3
MISTRAL_MAX_PDF_TOKENS=9000
MISTRAL_MAX_PAGES_PER_CHUNK=10

# SiliconFlow (DeepSeek-OCR) settings
SILICONFLOW_DEFAULT_MODEL=deepseek-ai/DeepSeek-OCR
SILICONFLOW_TIMEOUT_SECONDS=60
SILICONFLOW_RETRY_ATTEMPTS=3
SILICONFLOW_MAX_INPUT_TOKENS=3500
SILICONFLOW_CHUNK_OVERLAP_TOKENS=200

# ===================================
# Web Server Settings
# ===================================
FLASK_ENV=production
FLASK_DEBUG=false
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Maximum upload size (in bytes). 50MB = 52428800.
MAX_CONTENT_LENGTH=52428800
