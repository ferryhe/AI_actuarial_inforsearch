# AI Actuarial Info Search - Environment Variables Example
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!

# ===================================
# SENSITIVE CREDENTIALS ONLY
# ===================================
# Non-sensitive configuration has been moved to config/sites.yaml
# Edit configuration via Web UI Settings page or config/sites.yaml directly

# ===================================
# API Keys
# ===================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Get from: https://brave.com/search/api/
BRAVE_API_KEY=

# Get from: https://serpapi.com/
SERPAPI_API_KEY=

# Get from: https://console.mistral.ai/
MISTRAL_API_KEY=

# Get from: https://siliconflow.cn/
SILICONFLOW_API_KEY=

# ===================================
# API Base URLs (Optional Overrides)
# ===================================
# Override default API endpoints if using compatible gateways
# OPENAI_BASE_URL=https://api.openai.com/v1
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# ===================================
# Security Tokens
# ===================================
# Generate strong random tokens using:
# python -c "import secrets; print(secrets.token_urlsafe(32))"

# Required for configuration write operations
CONFIG_WRITE_AUTH_TOKEN=

# Required for file deletion operations (if enable_file_deletion=true in sites.yaml)
FILE_DELETION_AUTH_TOKEN=

# Flask secret key for session management
FLASK_SECRET_KEY=

# Bootstrap admin token for public deployments
# If set, the server will ensure an admin token exists matching this value.
BOOTSTRAP_ADMIN_TOKEN=
BOOTSTRAP_ADMIN_SUBJECT=bootstrap-admin

# Required for global logs API (if enable_global_logs_api=true in sites.yaml)
LOGS_READ_AUTH_TOKEN=

# ===================================
# Database Credentials (PostgreSQL only)
# ===================================
# Only needed if using PostgreSQL (configured in sites.yaml)
# For SQLite, no password is needed
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=ai_actuarial
# DB_USER=postgres
# DB_PASSWORD=your-strong-db-password

# ===================================
# CONFIGURATION MOVED TO sites.yaml
# ===================================
# The following configuration options are now in config/sites.yaml:
# - AI model selections (catalog, embeddings, chatbot, ocr)
# - RAG settings (chunking, similarity, index type)
# - Feature flags (auth, deletion, rate limiting)
# - Server settings (host, port, max upload size)
# - Timeouts, retries, temperature, tokens, etc.
#
# Edit via Web UI Settings page or edit config/sites.yaml directly.
# Changes to sites.yaml take effect immediately (no restart needed).
#
# Backward compatibility: If sections are missing from sites.yaml,
# the system will fall back to reading from environment variables.
